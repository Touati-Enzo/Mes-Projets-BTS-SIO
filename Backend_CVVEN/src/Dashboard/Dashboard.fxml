<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<BorderPane
    prefWidth="1200.0"
    prefHeight="700.0"
    stylesheets="@hotel-luxury.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="Dashboard.DashboardController">

    <!-- ══ SIDEBAR ══ -->
    <left>
        <VBox styleClass="sidebar" prefWidth="220.0" spacing="0">

            <!-- Logo -->
            <VBox styleClass="sidebar-logo-box" spacing="4" alignment="CENTER_LEFT">
                <Label text="✦ Prestige" styleClass="sidebar-logo"/>
                <Label text="HÔTEL &amp; SPA" styleClass="sidebar-subtitle"/>
            </VBox>

            <!-- Navigation -->
            <VBox spacing="2" VBox.vgrow="ALWAYS">
                <Label text="GESTION" styleClass="nav-section-label"/>

                <Button fx:id="navUsers"
                    text="  👤  Utilisateurs"
                    styleClass="nav-btn, nav-btn-active"
                    onAction="#showUsers"
                    maxWidth="Infinity"/>

                <Button fx:id="navChambres"
                    text="  🛏  Chambres"
                    styleClass="nav-btn"
                    onAction="#showChambres"
                    maxWidth="Infinity"/>

                <Button fx:id="navReservations"
                    text="  📋  Réservations"
                    styleClass="nav-btn"
                    onAction="#showReservations"
                    maxWidth="Infinity"/>

                <Region VBox.vgrow="ALWAYS"/>

                <Separator style="-fx-background-color: #1E2D45; -fx-opacity: 0.4;" prefWidth="180"/>

                <Button
                    text="  ⟵  Se déconnecter"
                    styleClass="nav-btn-logout"
                    onAction="#logout"
                    maxWidth="Infinity"/>
                <VBox.margin>
                    <Insets bottom="16"/>
                </VBox.margin>
            </VBox>
        </VBox>
    </left>

    <!-- ══ CONTENT ══ -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #0A0F1E;"/>
    </center>

</BorderPane>
